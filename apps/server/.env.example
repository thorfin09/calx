# Database connection URL for production (e.g. Neon PostgreSQL)
# IMPORTANT: Remove &channel_binding=require from the URL if present — it causes pg connection failures
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Port for server instance (platforms will override this automatically)
PORT=5000

# Set this on Render.com to your service's external URL — used for the keep-alive self-ping
# Render automatically provides this env variable, no manual action needed
RENDER_EXTERNAL_URL=https://your-service-name.onrender.com

# Frontend URL (for CORS reference)
FRONTEND_URL=https://calx-three.vercel.app
